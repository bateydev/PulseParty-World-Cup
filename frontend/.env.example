# PulseParty Frontend Environment Variables

# WebSocket API Gateway URL
# Development: ws://localhost:3001
# Production: wss://your-api-gateway-id.execute-api.region.amazonaws.com/prod
VITE_WEBSOCKET_URL=ws://localhost:3001

# REST API URL (if needed for HTTP endpoints)
# Development: http://localhost:3001
# Production: https://your-api-gateway-id.execute-api.region.amazonaws.com/prod
VITE_API_URL=http://localhost:3001

# AWS Cognito Configuration (for authenticated users)
# VITE_COGNITO_USER_POOL_ID=your-user-pool-id
# VITE_COGNITO_CLIENT_ID=your-client-id
# VITE_COGNITO_REGION=us-east-1
